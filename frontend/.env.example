# Base URL of the Laravel API backend.
# When set, the app tries the real API first and falls back to localStorage
# automatically if the backend is unreachable (no extra config needed).
#
# Local dev:  VITE_API_BASE_URL=http://localhost:8000
# Production: VITE_API_BASE_URL=https://your-laravel-app.up.railway.app
#
# Leave blank (or unset) to run in pure localStorage mode (default for demo).
VITE_API_BASE_URL=
