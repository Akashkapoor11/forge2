# Root .env.example — Docket Forge 2 Qualifier
# Copy relevant sections to frontend/.env and backend/.env

# ── Slack (required for OpenClaw + Hermes) ──────────────────────────────────
SLACK_BOT_TOKEN=xoxb-replace-with-your-bot-token
SLACK_APP_TOKEN=xapp-replace-with-your-app-level-token

# ── Model API keys (only one pair required; Ollama needs no key) ────────────
GROQ_API_KEY=gsk_replace-with-groq-key
GEMINI_API_KEY=replace-with-gemini-key

# ── Frontend (copy to frontend/.env) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api

# ── Backend (copy to backend/.env, then run: php artisan key:generate) ──────
APP_KEY=base64:replace-with-generated-key
APP_DEBUG=true
APP_URL=http://localhost:8000
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
